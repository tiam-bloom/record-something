# Auto detect text files and perform LF normalization
* text=auto

# Force batch scripts to use LF line endings
*.sh text eol=lf
*.bat text eol=crlf

# Kotlin and Gradle files
*.kt text
*.kts text
*.gradle text
*.gradle.kts text
*.properties text

# Markdown and documentation
*.md text
*.mdwn text
*.mdown text

# Enforce LF for these file types
*.java text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.apk binary
*.aab binary
